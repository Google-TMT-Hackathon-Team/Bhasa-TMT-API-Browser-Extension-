{
  "manifest_version": 3,
  "name": "TMT Translator",
  "version": "0.8.0",
  "description": "Real-time translation between English, Nepali, and Tamang — powered by Google TMT API",
  "action": {
    "default_popup": "popup.html",
    "default_title": "TMT Translator"
  },
  "options_page": "options.html",
  "permissions": ["storage", "activeTab", "contextMenus"],
  "host_permissions": ["https://tmt.ilprl.ku.edu.np/*"],
  "background": {
    "service_worker": "scripts/background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["scripts/content.js"],
      "run_at": "document_idle"
    }
  ],
  "commands": {
    "translate-selection": {
      "suggested_key": {
        "default": "Ctrl+Shift+T",
        "mac": "Command+Shift+T"
      },
      "description": "Translate selected text on current page"
    }
  },
  "icons": {
    "16": "icons/icons.png",
    "48": "icons/icons.png",
    "128": "icons/icons.png"
  }
}
