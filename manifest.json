{
  "manifest_version": 3,
  "name": "TMT Translator",
  "version": "0.4.0",
  "description": "Real-time translation between English, Nepali, and Tamang — powered by Google TMT API",
  "action": {
    "default_popup": "popup.html",
    "default_title": "TMT Translator"
  },
  "options_page": "options.html",
  "permissions": ["storage"],
  "host_permissions": ["https://tmt.ilprl.ku.edu.np/*"],
  "icons": {
    "16": "icons/icons.png",
    "48": "icons/icons.png",
    "128": "icons/icons.png"
  }
}
